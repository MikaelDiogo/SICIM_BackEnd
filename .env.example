# PostgreSQL / PostGIS (ver docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sicim
DB_PASSWORD=sicim_dev_pass
DB_NAME=sicim

NODE_ENV=development

# Segredo usado para assinar os tokens JWT - gerar um valor forte em produção
JWT_SECRET=change_me

# Porta em que a API sobe (opcional, padrão 3000)
PORT=3000

# Origem(ns) autorizadas para CORS, separadas por vírgula
CORS_ORIGIN=http://localhost:5173
